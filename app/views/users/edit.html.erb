<h1>Users#edit</h1>
<p>Find me in app/views/users/edit.html.erb</p>
<h1>User Edit</h1>
<%= form_with model: @user_edit do |f| %>
<div>
<p>First Name: <%= f.text_field :first_name %></p>
<p>Last Name: <%= f.text_field :family_name %></p>
</div>

<%= f.submit 'Update' %>
<% end %>

<hr> <!-- Add horizontal line -->

<%= link_to "Details Page", user_path(@user_edit.id) %>